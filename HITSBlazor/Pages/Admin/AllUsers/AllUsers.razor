@namespace HITSBlazor.Pages.Admin.AllUsers
@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Filters.CheckboxFilter
@using HITSBlazor.Components.Filters.RadioFilter
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Status
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Utils.EnumStyles
@using HITSBlazor.Utils.Models

<div class="page-content-with-header bg-white overflow-y-scroll">
    @if (_isLoading)
    {
        <TablePlaceholder />
    }
    else
    {
        <div class="w-100 bg-white p-3">
            <ListPageHeader HeaderText="@($"Список пользователей: {_users.Count}")" />
            <ListPageSearch ValueChanged="@((value) => SearchUser(value))" />
            <ListPageTable>
                <TableContent>
                    <TableHeader TableActionMenuIsEnable="true"
                                 Items="_userTableHeader"
                                 OrderChanged="@((value) => SortUser(value.Item1, value.Item2))" />
                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr>
                                <TableBodyRow>
                                    <div class="text-primary data-link" @onclick="@(() => ShowUserProfile(user.Id))">
                                        @user.Email
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    @user.FirstName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @user.LastName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @user.Telephone
                                </TableBodyRow>
                                <TableBodyRow>
                                    @user.StudyGroup
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    @(user.CreatedAt.HasValue? user.CreatedAt.Value.ToString("dd.MM.yyyy") : "Н/Д")
                                </TableBodyRow>
                                <TableBodyRow>
                                    @foreach (var role in user.Roles)
                                    {
                                        <Status Statustype="role" />
                                    }
                                </TableBodyRow>
                                <TableActionMenu ItemId="@user.Id"
                                                 OnAction="OnUserAction"
                                                 ActionIds="GetActions(user)" />
                            </tr>
                        }
                    </tbody>
                </TableContent>
                <FilterContent>
                    <CheckboxFilter T="EnumViewModel<RoleType>" 
                                    AllValues="_filterRoleTypes"
                                    Label="Роли"
                                    @bind-SelectedValues="SelectedUserRoles"
                                    FilterChanged="LoadUsersAsync"/>
                    <!-- TODO: реализовать фильтр -->
                    <RadioFilter Label="Студенты"
                                 Value1Text="В команде"
                                 Value2Text="Не в команде"
                                 @bind-Value="InTeam"
                                 OnFilterChanged="@LoadUsersAsync" />

                    <div class="w-100 d-flex justify-content-center">
                        <Button BtnType="ButtonType.Button"
                                Variant="ButtonVariant.Danger"
                                Text="Сбросить фильтры"
                                IconStyle="bi-x-lg"
                                OnButtonClick="ResetFilters" />
                    </div>
                </FilterContent>
            </ListPageTable>
        </div>
    }
</div>