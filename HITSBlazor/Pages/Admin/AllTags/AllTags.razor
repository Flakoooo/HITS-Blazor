@namespace HITSBlazor.Pages.Admin.AllTags
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Filters.RadioFilter
@using HITSBlazor.Components.Filters.ResetFilterButton
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Utils.Models

<div class="page-content-with-header bg-white overflow-y-scroll">
    @if (_isLoading)
    {
        <TablePlaceholder />
    }
    else
    {
        <div class="w-100 bg-white p-3">
            <ListPageHeader HeaderText="@($"Список тегов: {_tags.Count}")"
                            CreateButtonText="Добавить компетенцию" 
                            ShowCreateButton="true" 
                            OnButtonClick="() => ShowTagModal()" />
            <ListPageSearch ValueChanged="@((value) => SeacrhTag(value))" />
            <ListPageTable>
                <TableContent>
                    <TableHeader TableActionMenuIsEnable="true"
                                 Items="_tagsTableHeader" />
                    <tbody>
                        @foreach (var tag in _tags)
                        {
                            <tr>
                                <TableBodyRow IsCentered="true">
                                    <div class="bi bi-circle-fill fs-6 mt-1" style="@($"color: {tag.Color};")">
                                        <div></div>
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    <div class="data-link">
                                        @tag.Name
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    <div class="@(tag.Confirmed ? string.Empty : "text-danger")">
                                        @(tag.Confirmed ? "Утвержден" : "На рассмотрении")
                                    </div>
                                </TableBodyRow>
                                <TableActionMenu ItemId="@tag.Id"
                                                 OnAction="OnTagAction"
                                                 ActionIds="@GetTableActions(tag)" />
                            </tr>
                        }
                    </tbody>
                </TableContent>
                <FilterContent>
                    <RadioFilter T="ValueViewModel<bool?>"
                                 Label="Статус"
                                 AllValues="_confirmedFilterValues"
                                 @bind-Value="IsConfirmed"
                                 OnFilterChanged="LoadTagsAsync" />
                    <ResetFilterButton ResetMethod="ResetFilters" />
                </FilterContent>
            </ListPageTable>
        </div>
    }
</div>