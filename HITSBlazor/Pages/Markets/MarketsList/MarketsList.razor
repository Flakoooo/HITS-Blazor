@namespace HITSBlazor.Pages.Markets.MarketsList
@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Filters.CheckboxFilter
@using HITSBlazor.Components.Filters.ResetFilterButton
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Statuses.EnumStatus
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Models.Markets.Enums
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Utils.Models

<div class="overflow-y-scroll bg-white h-auto">
    @if (_isLoading)
    {
        <TablePlaceholder />
    }
    else
    {
        <div class="w-100 p-3">
            <ListPageHeader IsLoading="_isLoading"
                            HeaderText="@($"Список бирж: {_markets.Count}")" 
                            ShowCreateButton="true"
                            CreateButtonText="Создать биржу" 
                            OnButtonClick="() => ShowMarketModal()" />
            <ListPageSearch IsLoading="_isLoading" ValueChanged="@((value) => SearchMarket(value))" />
            <ListPageTable IsLoading="_isLoading" HeaderItems="_marketTableHeader" TableActionMenuIsEnable="true" OrderMethod="SortMarket">
                <TableContent>
                    <tbody>
                        @foreach(var market in _markets)
                        {
                            <tr>
                                <TableBodyRow>
                                    <div class="data-link" @onclick="() => OpenMarket(market.Id)">
                                        @market.Name
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <EnumStatus Statustype="market.Status" />
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    @market.StartDate.ToString("dd.MM.yyyy")
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    @market.FinishDate.ToString("dd.MM.yyyy")
                                </TableBodyRow>
                                <TableActionMenu ItemId="@market.Id"
                                                 OnAction="OnMarketAction"
                                                 ActionIds="GetTableActions(market)" />
                            </tr>
                        }
                    </tbody>
                </TableContent>
                <FilterContent>
                    <CheckboxFilter IsLoading="_isLoading"
                                    T="EnumViewModel<MarketStatus>" 
                                    Label="Статус" 
                                    AllValues="_filterMarketStatus"
                                    FilterChanged="LoadMarketsAsync"
                                    @bind-SelectedValues="SelectedStatuses" />
                    <ResetFilterButton IsLoading="_isLoading" ResetMethod="ResetFilters" />
                </FilterContent>
            </ListPageTable>
        </div>
    }
</div>