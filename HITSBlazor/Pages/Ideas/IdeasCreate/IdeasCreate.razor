@using HITSBlazor.Components.Button
@using HITSBlazor.Components.InputDropdowns.CompanyDropdown
@using HITSBlazor.Components.InputDropdowns.ContactPersonDropdown
@using HITSBlazor.Components.InputDropdowns.SkillDropdown
@using HITSBlazor.Components.Inputs.Select
@using HITSBlazor.Components.Placeholder
@using HITSBlazor.Components.ProgressBar
@using HITSBlazor.Models.Common.Entities
@using HITSBlazor.Models.Common.Enums
@using HITSBlazor.Models.Ideas.Enums
@using HITSBlazor.Services.Ideas

<PageTitle>Портал ВШЦТ</PageTitle>

<!-- TODO: Реализовать валидацию -->
<div class="new-idea page-content-with-header">
    <form class="p-3 bg-white w-100 h-100 overflow-auto idea-form">
        <span class="fs-2 text-primary">Создание идеи</span>
        <div class="w-75 d-flex flex-column gap-3">
            <div class="d-flex flex-column gap-3">
                <div class="w-100">
                    <label class="form-label text-primary">
                        Название идеи*
                        <i class="bi bi-patch-question hint"></i>
                    </label>
                    <div class="input-group">
                        <input type="text" 
                               placeholder="Введите название идеи" 
                               @bind="_ideasCreateModel.Name"
                               @bind:event="oninput"
                               class="form-control rounded-end" />
                        <span class="invalid-feedback">Поле не заполнено</span>
                    </div>
                </div>
                <div class="d-flex flex-column w-100 h-100">
                    <label class="form-label text-primary">
                        Проблема*
                        <i class="bi bi-patch-question hint"></i>
                    </label>
                    <div class="input-group h-100">
                        <textarea placeholder="Опишите проблему, которую решает ваша идея" 
                                  @bind="_ideasCreateModel.Problem"
                                  @bind:event="oninput"
                                  class="form-control rounded-end">
                        </textarea>
                        <span class="invalid-feedback">Поле не заполнено</span>
                    </div>
                </div>
                <div class="d-flex flex-column w-100 h-100">
                    <label class="form-label text-primary">
                        Предлагаемое решение*
                        <i class="bi bi-patch-question hint"></i>
                    </label>
                    <div class="input-group h-100">
                        <textarea placeholder="Опишите, что вы предлагаете для решения проблемы" 
                                  @bind="_ideasCreateModel.Solution"
                                  @bind:event="oninput"
                                  class="form-control rounded-end">
                        </textarea>
                        <span class="invalid-feedback">Поле не заполнено</span>
                    </div>
                </div>
                <div class="d-flex flex-column w-100 h-100">
                    <label class="form-label text-primary">
                        Ожидаемый результат*
                        <i class="bi bi-patch-question hint"></i>
                    </label>
                    <div class="input-group h-100">
                        <textarea placeholder="Опишите ожидаемый результат" 
                                  @bind="_ideasCreateModel.Result"
                                  @bind:event="oninput"
                                  class="form-control rounded-end">
                        </textarea>
                        <span class="invalid-feedback">Поле не заполнено</span>
                    </div>
                </div>
                <div class="d-flex flex-column w-100 h-100">
                    <label class="form-label text-primary">
                        Описание необходимых ресурсов для реализации*
                        <i class="bi bi-patch-question hint"></i>
                    </label>
                    <div class="input-group h-100">
                        <textarea placeholder="Укажите список требуемых для выполнения проекта ресурсов" 
                                  @bind="_ideasCreateModel.Description"
                                  @bind:event="oninput"
                                  class="form-control rounded-end">
                        </textarea>
                        <span class="invalid-feedback">Поле не заполнено</span>
                    </div>
                </div>
                <div>
                    <span class="fs-6 text-primary">
                        Желаемое количество участников в команде*
                    </span>
                    <i class="bi bi-patch-question hint"></i>
                <div class="mt-2 d-flex gap-3">
                    <div class="w-100">
                        <div class="input-group">
                            <input type="number" 
                                   max="30" 
                                   min="2" 
                                   placeholder="Минимальное количество: 2" 
                                   @bind="_ideasCreateModel.MinTeamSize"
                                   @bind:event="oninput"
                                   class="form-control rounded-end" />
                            <span class="invalid-feedback">Значение должно быть от 2 до 30</span>
                        </div>
                    </div>
                    <div class="w-100">
                        <div class="input-group">
                            <input type="number" 
                                   max="30" 
                                   min="2" 
                                   placeholder="Максимальное количество: 30" 
                                   @bind="_ideasCreateModel.MaxTeamSize"
                                   @bind:event="oninput"
                                   class="form-control rounded-end" />
                            <span class="invalid-feedback">Значение должно быть от 2 до 30</span>
                        </div>
                    </div>
                </div>
                </div>
            </div>
            <div>
                <span class="fs-6 text-primary">Стек технологий*</span>
                <i class="bi bi-patch-question hint"></i>
                @if (_isLoading)
                {
                    <div class="mt-2 w-100 d-flex gap-3">
                        @for (int p = 0; p < 4; ++p)
                        {
                            <Placeholder Height="PlaceholderHeight.Small" />
                        }
                    </div>
                }
                else 
                {
                    <div class="mt-2 w-100 stack-categories">
                        <SkillDropdown SkillType="SkillType.Language" 
                                       AllSkills="@_languageSkills"
                                       @bind-SelectedSkills="@_selectedLanguageSkills"
                                       SearchFunction="@SearchSkillsAsync" />
                        <SkillDropdown SkillType="SkillType.Framework"
                                       AllSkills="@_frameworkSkills"
                                       @bind-SelectedSkills="@_selectedFrameworkSkills"
                                       SearchFunction="@SearchSkillsAsync" />
                        <SkillDropdown SkillType="SkillType.Database" 
                                       AllSkills="@_databaseSkills"
                                       @bind-SelectedSkills="@_selectedDatabaseSkills"
                                       SearchFunction="@SearchSkillsAsync" />
                        <SkillDropdown SkillType="SkillType.Devops" 
                                       AllSkills="@_devopsSkills"
                                       @bind-SelectedSkills="@_selectedDevopsSkills"
                                       SearchFunction="@SearchSkillsAsync" />
                    </div>
                }
            </div>
            <CompanyDropdown AllCompanies="@_companies"
                             @bind-SelectedCompany="@SelectedCompany"
                             SearchFunction="@SearchCompaniesAsync" />
            @if (SelectedCompany is not null)
            {
                <ContactPersonDropdown CompanyId="@SelectedCompany.Id"
                                       AllContactPersons="@SelectedCompany.Users"
                                       @bind-SelectedContactPerson="@SelectedContactPerson"
                                       SearchFunction="@SearchContactPersonsAsync" />
            }
            <div class="row">
                <div class="col">
                    <Select Label="Пригодность"
                            @bind-Value="@SuitabilityScore"
                            Options="IdeasRatingCategories.SuitabilityOptions" />
                </div>
                <div class="col">
                    <Select Label="Бюджет" 
                            @bind-Value="@BudgetScore" 
                            Options="IdeasRatingCategories.BudgetOptions" />
                </div>
            </div>
            <div class="col">
                <ProgressBar Text="Предварительная оценка" 
                             Score="_preAssessmentScore" 
                             CategoryCounts="5" />
            </div>
            <div class="idea-form-submit-buttons">
                @if (string.IsNullOrWhiteSpace(IdeaId))
                {
                    <Button BtnType="ButtonType.Button" 
                            Variant="ButtonVariant.Primary"
                            Text="Сохранить черновик"
                            OnButtonClick="@(() => CreateIdea(IdeaStatusType.New))" />
                    <Button BtnType="ButtonType.Button"
                            Variant="ButtonVariant.Success"
                            Text="Отправить на согласование"
                            OnButtonClick="@(() => CreateIdea(IdeaStatusType.OnApproval))" />
                }
                else
                {
                    <Button BtnType="ButtonType.Button"
                            Variant="ButtonVariant.Primary"
                            Text="Сохранить изменения"
                            OnButtonClick="UpdateIdea" />
                }
            </div>
        </div>
    </form>
</div>

