@namespace HITSBlazor.Pages.Ideas.IdeasList
@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Filters.CheckboxFilter
@using HITSBlazor.Components.Inputs.CheckboxDropdown
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Ideas.Enums
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Utils
@using HITSBlazor.Utils.EnumStyles
@using HITSBlazor.Utils.Models

<div class="bg-white ideas-list page-content-with-header">
    @if (_isLoading)
    {
        <TablePlaceholder Header="false" />
    }
    else
    {
        <div class="w-100 bg-white p-3">
            <ListPageHeader HeaderText="@($"Список идей: {_ideas.Count}")" 
                            ShowCreateButton="AuthService.CurrentUser?.Role is RoleType.Initiator or RoleType.Admin"
                            CreateButtonText="Создать идею" 
                            OnButtonClick="@(() => NavigationService.NavigateToAsync("ideas/create"))" />
            <ListPageSearch ValueChanged="@((value) => SearchIdea(value))" />
            <!-- TODO: если идей нет, то сообщить пользователю, что идеи не найдены, н это как ИДЕЯ -->
            <ListPageTable>
                <TableContent>
                    <tbody>
                        @foreach(var idea in _ideas)
                        {
                            <tr>
                                <TableBodyRow>
                                    <div class="bi bi-circle-fill fs-6 mt-1 @(idea.IsChecked ? "text-success" : "text-secondary")">
                                        <div></div>
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    <div @onclick="@(() => ShowIdea(idea.Id))" class="data-link">
                                        <div>@idea.Name</div>
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <div class="px-2 py-1 rounded-4 @idea.Status.GetStyle()">
                                        <div>@(EnumViewModel<IdeaStatusType>.GetTranslation(idea.Status))</div>
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <div>@idea.CreatedAt.ToString("dd.MM.yyyy")</div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <div>@idea.ModifiedAt.ToString("dd.MM.yyyy")</div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <div class="@idea.PreAssessment.GetStyle()">
                                        <div>@idea.PreAssessment</div>
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow IsCentered="true">
                                    <div class="@idea.Rating.GetStyle()">
                                        <div>@idea.Rating</div>
                                    </div>
                                </TableBodyRow>
                                <TableActionMenu ItemId="@idea.Id"
                                                    OnAction="OnIdeaAction"
                                                    ActionIds="@(new Dictionary<MenuAction, object> { 
                                                    [MenuAction.View] = idea.Id,
                                                    [MenuAction.Edit] = idea.Id,
                                                    [MenuAction.Delete] = idea
                                                    })" />
                            </tr>
                        }
                    </tbody>
                </TableContent>
                <FilterContent>
                    <CheckboxFilter T="EnumViewModel<IdeaStatusType>" 
                                    Label="Статус" 
                                    AllValues="_filterIdeaStatus"
                                    FilterChanged="LoadIdeasAsync"
                                    @bind-SelectedValues="SelectedStatuses" />
                    @if (AuthService.CurrentUser?.Role is RoleType.Admin or RoleType.Expert)
                    {
                        <div class="w-100">
                            <Typography FontSize="6" CustomClass="fw-semibold">
                                Экспертиза
                            </Typography>
                            <div class="list-page-filter-choices">
                                <div class="px-2 py-1 rounded-1 list-page-filter-choice">
                                    <div class="d-flex">
                                        <input type="checkbox"
                                               checked="@_unapprovedIdeasByCurrentUser"
                                               @onchange="@(e => FindOnConfirmation((bool)e.Value!))"
                                               class="form-check-input" />
                                        <Typography CustomClass="form-check-label ms-2">
                                            Неутвержденные идеи
                                        </Typography>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="w-100 d-flex justify-content-center">
                        <Button BtnType="ButtonType.Button" 
                                Variant="ButtonVariant.Danger"
                                Text="Сбросить фильтры" 
                                IconStyle="bi-x-lg" 
                                OnButtonClick="ResetFilters" />
                    </div>
                </FilterContent>
            </ListPageTable>
        </div>
    }
</div>