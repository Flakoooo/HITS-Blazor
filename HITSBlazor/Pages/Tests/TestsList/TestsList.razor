@namespace HITSBlazor.Pages.Tests.TestsList
@using HITSBlazor.Components.InputSearch
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableComponent
@using HITSBlazor.Components.Tables.TableHeader

<div class="page-content-with-header bg-white">
    <div class="w-100 bg-white p-3">
        <!-- TODO: проверить, кто может видеть эту кнопку -->
        <ListPageHeader IsLoading="_isLoading"
                        HeaderText="@($"Список тестов: {_tests.Count}")"
                        ShowCreateButton="true"
                        CreateButtonText="Результаты пользователей" 
                        OnButtonClick="@(() => NavigationService.NavigateToAsync("tests/results"))" />
        <InputSearch Width="50" IsLoading="_isLoading" ValueChanged="@((value) => SearchTest(value))" DebounceDelay="500" />
        <TableComponent IsLoading="_isLoading" HeaderItems="_testTableHeader">
            <TableContent>
                @foreach (var test in _tests)
                {
                    <tr>
                        <TableBodyRow>
                            <div class="text-primary data-link" @onclick="@(() => ShowTestModal(test))">
                                @test.Name
                            </div>
                        </TableBodyRow>
                    </tr>
                }
            </TableContent>
        </TableComponent>
    </div>
</div>