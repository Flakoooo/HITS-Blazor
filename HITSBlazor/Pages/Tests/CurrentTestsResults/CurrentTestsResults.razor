@namespace HITSBlazor.Pages.Tests.CurrentTestsResults
@using HITSBlazor.Components.InputSearch
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableComponent
@using HITSBlazor.Components.Tables.TableHeader

<div class="bg-white h-auto">
    <div class="w-100 bg-white p-3">
        <!-- TODO: реализовать выгрузку результатов -->
        <ListPageHeader IsLoading="_isLoading"
                        HeaderText="@($"Результаты: {_searchedResults.Count}")"
                        ShowCreateButton="true"
                        CreateButtonText="Скачать результаты" 
                        CreateButtonIconStyle="bi-filetype-txt" />
        <InputSearch Width="50" IsLoading="_isLoading" ValueChanged="@((value) => SearchResult(value))" DebounceDelay="500" />
        <TableComponent IsLoading="_isLoading" HeaderItems="_resultTableHeader">
            <TableContent>
                @foreach (var result in _searchedResults)
                {
                    <tr>
                        <TableBodyRow>
                            <div class="text-primary data-link" @onclick="() => ModalService.ShowProfileModal(result.User.Id)">
                                @result.User.Email
                            </div>
                        </TableBodyRow>
                        <TableBodyRow>@result.User.FirstName</TableBodyRow>
                        <TableBodyRow>@result.User.LastName</TableBodyRow>
                        <TableBodyRow>@result.User.StudyGroup</TableBodyRow>
                        <TableBodyRow>
                            @((MarkupString)result.TestResultValue.Replace("\n", "<br>"))
                        </TableBodyRow>
                    </tr>
                }
            </TableContent>
        </TableComponent>
    </div>
</div>