@namespace HITSBlazor.Pages.Tests.ResultsList
@using HITSBlazor.Components.Filters.CheckboxFilter
@using HITSBlazor.Components.Filters.RadioFilter
@using HITSBlazor.Components.Filters.ResetFilterButton
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Utils.Models

<div class="h-auto bg-white">
    <div class="w-100 bg-white p-3">
        <ListPageHeader IsLoading="_isLoading" HeaderText="@($"Список тестов: {_results.Count}")" />
        <ListPageSearch IsLoading="_isLoading" ValueChanged="@((value) => SearchResult(value))" />
        <ListPageTable>
            <TableContent>
                @if (_isLoading)
                {
                    <TablePlaceholder />
                }
                else
                {
                    <TableHeader Items="_resultTableHeader" />
                    <tbody>
                        @foreach (var result in _results)
                        {
                            <tr>
                                <TableBodyRow>
                                    <div class="text-primary data-link">
                                        @result.User.Email
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.FirstName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.LastName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.StudyGroup
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.BelbinResult
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.MindResult
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.TemperResult
                                </TableBodyRow>
                            </tr>
                        }
                    </tbody>
                }
            </TableContent>
            <FilterContent>
                <CheckboxFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Учебная группа" AllValues="_studyFilterValues" @bind-SelectedValues="SelectedStudyGroups" />
                <CheckboxFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Тест Белбина" AllValues="_belbinResultFilterValues" @bind-SelectedValues="SelectedBelbinResult" />
                <RadioFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Стиль мышления" AllValues="_mindResultFilterValues" @bind-Value="SelectedMindResult" />
                <CheckboxFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Экстраверсия" AllValues="_temperExtraversionFilterValues" @bind-SelectedValues="SelectedTemperExtraversion" />
                <CheckboxFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Нейротизм" AllValues="_temperNeurotismFilterValues" @bind-SelectedValues="SelectedTemperNeurotism" />
                <CheckboxFilter T="ValueViewModel<string>" IsLoading="_isLoading" Label="Ложь" AllValues="_temperLieFilterValues" @bind-SelectedValues="SelectedTemperLie" />
                <ResetFilterButton ResetMethod="ResetFilters" />
            </FilterContent>
        </ListPageTable>
    </div>
</div>