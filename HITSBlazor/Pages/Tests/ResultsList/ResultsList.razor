@namespace HITSBlazor.Pages.Tests.ResultsList
@using HITSBlazor.Components.Filters.CheckboxFilter
@using HITSBlazor.Components.Filters.RadioFilter
@using HITSBlazor.Components.Filters.ResetFilterButton
@using HITSBlazor.Components.ListPageComponents.ListPageHeader
@using HITSBlazor.Components.ListPageComponents.ListPageSearch
@using HITSBlazor.Components.ListPageComponents.ListPageTable
@using HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Components.Placeholders.TablePlaceholder
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Utils.Models

<div class="h-auto bg-white">
    <div class="w-100 bg-white p-3">
        <ListPageHeader IsLoading="_isLoading" HeaderText="@($"Все результаты: {_results.Count}")" />
        <ListPageSearch IsLoading="_isLoading" ValueChanged="@((value) => SearchResult(value))" />
        <ListPageTable>
            <TableContent>
                @if (_isLoading)
                {
                    <TablePlaceholder />
                }
                else
                {
                    <TableHeader Items="_resultTableHeader" />
                    <tbody>
                        @foreach (var result in _results)
                        {
                            <tr>
                                <TableBodyRow>
                                    <div class="text-primary data-link" @onclick="() => ModalService.ShowProfileModal(result.User.Id)">
                                        @result.User.Email
                                    </div>
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.FirstName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.LastName
                                </TableBodyRow>
                                <TableBodyRow>
                                    @result.User.StudyGroup
                                </TableBodyRow>
                                <TableBodyRow>
                                    @((MarkupString)result.BelbinResult.Replace("\n", "<br>"))
                                </TableBodyRow>
                                <TableBodyRow>
                                    @((MarkupString)result.MindResult.Replace("\n", "<br>"))
                                </TableBodyRow>
                                <TableBodyRow>
                                    @((MarkupString)result.TemperResult.Replace("\n", "<br>"))
                                </TableBodyRow>
                            </tr>
                        }
                    </tbody>
                }
            </TableContent>
            <FilterContent>
                <CheckboxFilter T="ValueViewModel<string>" 
                                IsLoading="_isLoading" 
                                Label="Учебная группа" 
                                AllValues="_studyFilterValues" 
                                @bind-SelectedValues="SelectedStudyGroups" 
                                FilterChanged="LoadTestsResultsAsync" />
                <CheckboxFilter T="ValueViewModel<string>" 
                                IsLoading="_isLoading"
                                Label="Тест Белбина" 
                                AllValues="_belbinResultFilterValues" 
                                @bind-SelectedValues="SelectedBelbinResult" 
                                FilterChanged="LoadTestsResultsAsync" />
                <RadioFilter T="ValueViewModel<string>" 
                             IsLoading="_isLoading" 
                             Label="Стиль мышления" 
                             AllValues="_mindResultFilterValues" 
                             @bind-Value="SelectedMindResult" 
                             OnFilterChanged="LoadTestsResultsAsync" />
                <CheckboxFilter T="ValueViewModel<string>" 
                                IsLoading="_isLoading" 
                                Label="Экстраверсия" 
                                AllValues="_temperExtraversionFilterValues" 
                                @bind-SelectedValues="SelectedTemperExtraversion" 
                                FilterChanged="LoadTestsResultsAsync" />
                <CheckboxFilter T="ValueViewModel<string>" 
                                IsLoading="_isLoading" 
                                Label="Нейротизм" 
                                AllValues="_temperNeurotismFilterValues" 
                                @bind-SelectedValues="SelectedTemperNeurotism" 
                                FilterChanged="LoadTestsResultsAsync" />
                <CheckboxFilter T="ValueViewModel<string>" 
                                IsLoading="_isLoading" 
                                Label="Ложь" 
                                AllValues="_temperLieFilterValues" 
                                @bind-SelectedValues="SelectedTemperLie" 
                                FilterChanged="LoadTestsResultsAsync" />
                <ResetFilterButton IsLoading="_isLoading" 
                                   ResetMethod="ResetFilters" />
            </FilterContent>
        </ListPageTable>
    </div>
</div>