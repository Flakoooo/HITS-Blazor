@namespace HITSBlazor.Pages.Teams.TeamsCreate
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.InputDropdowns.SkillDropdown
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Inputs.RadioDropdown
@using HITSBlazor.Components.Inputs.TextArea
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Common.Enums
@using HITSBlazor.Models.Users.Entities
@using HITSBlazor.Utils
@using HITSBlazor.Utils.Models

<div class="bg-white page-content-with-header">
    <div class="team-form w-100 h-100 bg-white p-3 overflow-auto">
        <div class="team-form-content w-75">
            <Typography FontSize="2">
                Создание команды
            </Typography>
            <Input Label="Название команды*" 
                   Placeholder="Введите название команды" 
                   NeedValidation="true" 
                   @bind-Value="_value" />
            <TextArea Label="Описание команды*" 
                      Placeholder="Введите описание команды" 
                      NeedValidation="true" 
                      @bind-Value="_value" />
            <div class="w-100">
                <Typography FontSize="2" TextColor="TextColor.Primary">
                    Тип команды*
                </Typography>
                <div class="my-2 d-flex gap-3">
                    <div class="team-type w-50 p-2 rounded-3 border border-2 @(!TeamsCreateModel.Closed ? "team-type-active border-primary border-opacity-75" : string.Empty)">
                        <div class="team-type-icon rounded-circle bg-success bg-opacity-25">
                            <i class="fs-2 text-success bi bi-folder2-open"></i>
                        </div>
                        <div class="team-type-text">
                            <Typography FontSize="4">
                                Открытая
                            </Typography>
                            <Typography FontSize="6" TextColor="TextColor.Secondary">
                                Любой пользователь системы может отправить заявку на присоединение в команду
                            </Typography>
                        </div>
                    </div>
                    <div class="team-type w-50 p-2 rounded-3 border border-2 @(TeamsCreateModel.Closed ? "team-type-active border-primary border-opacity-75" : string.Empty)">
                        <div class="team-type-icon rounded-circle bg-danger bg-opacity-25">
                            <i class="fs-2 text-danger bi bi-shield-lock"></i>
                        </div>
                        <div class="team-type-text">
                            <Typography FontSize="4">
                                Закрытая
                            </Typography>
                            <Typography FontSize="6" TextColor="TextColor.Secondary">
                                Пользователь портала может присоединиться в команду только по приглашению
                            </Typography>
                        </div>
                    </div>
                </div>
            </div>
            <div class="w-100 d-flex flex-column gap-3">
                <Typography FontSize="6" TextColor="TextColor.Primary">
                    Желаемые компетенции*
                </Typography>
                <div class="mt-2 w-100 stack-categories">
                    <SkillDropdown SkillType="SkillType.Language"
                                   @bind-SelectedSkills="@SelectedLanguageSkills" />
                    <SkillDropdown SkillType="SkillType.Framework"
                                   @bind-SelectedSkills="@SelectedFrameworkSkills" />
                    <SkillDropdown SkillType="SkillType.Database"
                                   @bind-SelectedSkills="@SelectedDatabaseSkills" />
                    <SkillDropdown SkillType="SkillType.Devops"
                                   @bind-SelectedSkills="@SelectedDevopsSkills" />
                </div>
            </div>
            <div class="team w-100">             
                <RadioDropdown T="User" 
                               Label="Владелец команды*" 
                               Placeholder="Выберите владельца"
                               IsDisabled="true" 
                               @bind-Value="TeamsCreateModel.Owner"
                               AllValues="TeamMembers"/>
                <RadioDropdown T="User"
                               Label="Владелец команды*"
                               Placeholder="Выберите владельца"
                               IsDisabled="true"
                               @bind-Value="TeamsCreateModel.Leader"
                               AllValues="TeamMembers" />
                <!-- combobox поле с выбором участников -->
            </div>
            <div>
                <!-- Блок с какимито графиками? -->
            </div>
            <Button BtnType="ButtonType.Button" Variant="ButtonVariant.Success" Text="Создать команду" />
        </div>
    </div>
</div>