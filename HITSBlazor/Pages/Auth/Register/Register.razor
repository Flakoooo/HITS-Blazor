@namespace HITSBlazor.Pages.Auth.Register
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Typography
@using HITSBlazor.Services
@using HITSBlazor.Utils
@using HITSBlazor.Utils.Validation

<PageTitle>Регистрация</PageTitle>

<div class="w-100 overflow-y-scroll auth-card-layout">
    <div class="p-3 auth-card">
        <div class="p-3 rounded-3 shadow auth-card-content">
            <Typography FontSize="3" TextColor="TextColor.Primary" CustomClass="text-center">
                Регистрация
            </Typography>
            <Input IconStyle="&#64;" 
                   Placeholder="Введите email" 
                   @bind-Value="_registerModel.Email"
                   NeedValidation="_submitted"
                   IsDisabled="IsEmailDisabled"
                   CustomValidation="UserValidation.EmailValidation" />
            <Input IconStyle="bi-fonts"
                   Placeholder="Введите имя"
                   @bind-Value="_registerModel.FirstName"
                   NeedValidation="_submitted"
                   CustomValidation="UserValidation.FirstNameValidation" />
            <Input IconStyle="bi-fonts"
                   Placeholder="Введите фамилию"
                   @bind-Value="_registerModel.LastName"
                   NeedValidation="_submitted"
                   CustomValidation="UserValidation.LastNameValidation" />
            <div class="input-group">
                <span class="input-group-text fs-6">
                    <i class="bi bi-telephone"></i>
                </span>
                <input type="tel"
                       @bind:get="_phoneInput"
                       @bind:set="HandlePhoneInput"
                       @bind:event="oninput"
                       inputmode="numeric"
                       class="form-control"
                       placeholder="+7 (___) ___-__-__"
                       maxlength="18" />
            </div>
            <Input IconStyle="bi-people"
                   Placeholder="Введите номер группы"
                   @bind-Value="_registerModel.StudyGroup" />
            <Input IconStyle="bi-key"
                   Placeholder="Введите пароль"
                   InputType="InputType.Password"
                   @bind-Value="_registerModel.Password"
                   NeedValidation="_submitted"
                   CustomValidation="UserValidation.PasswordValidation" />
            <Button Text="Зарегистрироваться" 
                    LoadingText="Регистрация" 
                    InProgress="_submitting"
                    Variant="ButtonVariant.Primary" 
                    OnButtonClick="HandleRegister" />
        </div>
    </div>
</div>