@namespace HITSBlazor.Pages.Auth.RecoveryPassword
@using HITSBlazor.Components
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Typography
@using HITSBlazor.Services
@using HITSBlazor.Utils
@using HITSBlazor.Utils.Models

<PageTitle>Восстановление пароля</PageTitle>

<div class="w-100 overflow-y-scroll auth-card-layout">
    <div class="p-3 auth-card">
        <div class="p-3 rounded-3 shadow auth-card-content">
            <Typography FontSize="3" TextColor="TextColor.Primary" CustomClass="text-center">
                Восстановление пароля
            </Typography>
            <Input IconStyle="&#64;" 
                   Placeholder="Введите почту" 
                   @bind-Value="recoveryModel.Email" />
            <Button Variant="ButtonVariant.Primary" 
                    InProgress="isLoading" 
                    Text="Отправить"
                    LoadingText="Отправка"
                    OnButtonClick="HandleRecovery" />
        </div>
    </div>
</div>