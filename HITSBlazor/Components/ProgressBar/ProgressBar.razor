@namespace HITSBlazor.Components.ProgressBar
@using HITSBlazor.Components.Placeholder

<span class="fs-6 text-primary">@Text: @(Score is null ? "вычисление" : Score)@($"{new string('.', _dotCount)}")</span>
@if (_animationTimer is not null || Score is null)
{
    <Placeholder />
}
else
{
    <div class="progress w-100 mt-2">
        <div class="progress-bar progress-bar-animated" style="@_progressStyle"></div>
    </div>
}