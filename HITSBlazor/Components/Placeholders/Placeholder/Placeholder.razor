@namespace HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Utils.Models

<div class="placeholder-glow @Width">
    <span class="placeholder w-100 bg-secondary rounded @heightClass @AdditionalClass" style="@heightStyle"></span>
</div>

@code {
    [Parameter]
    public string Width { get; set; } = "w-100";

    [Parameter]
    public PlaceholderHeight Height { get; set; } = PlaceholderHeight.None;

    [Parameter]
    public string AdditionalClass { get; set; } = string.Empty;

    private string heightClass = string.Empty;
    private string heightStyle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        (heightClass, heightStyle) = Height switch
        {
            PlaceholderHeight.Smaller => ("smaller", "height: 40px;"),
            PlaceholderHeight.Small => ("small", "height: 50px;"),
            PlaceholderHeight.Regular => ("regular", "height: 70px;"),
            PlaceholderHeight.Medium => ("medium", "height: 100px;"),
            PlaceholderHeight.Second => ("second", "height: 2000px;"),
            PlaceholderHeight.None or _ => (string.Empty, string.Empty)
        };
    }
}