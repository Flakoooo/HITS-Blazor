@namespace HITSBlazor.Components.ProjectViewComponents.ProjectViewActiveSprintTasks
@using HITSBlazor.Components.Hint
@using HITSBlazor.Components.Modals.CenterModals.FinishSprintModal
@using HITSBlazor.Components.Tags
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Projects.Entities
@using HITSBlazor.Models.Users.Entities
@using HITSBlazor.Pages
@using HITSBlazor.Services.Auth
@using HITSBlazor.Services.Modal
@using HITSBlazor.Utils.EnumUIConverters
@inherits ListPageDataLoader

@using HITSTaskStatus = HITSBlazor.Models.Projects.Enums.TaskStatus;

<div class="w-100 sprint-column-wrapper"
     data-category="@TaskCategory.ToString()"
     @onmouseup="HandleDrop"
     @onmouseenter="() => _isDragOver = _draggedTask != null && _draggedTask.Status != TaskCategory && CanDropTask(_draggedTask)"
     @onmouseleave="() => _isDragOver = false"
     style="@(IsDragging ? "user-select: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none;" : "")">
    @{
        string color = GetTaskCategoryColor(TaskCategory);
        bool canDrop = _draggedTask != null && CanDropTask(_draggedTask);
        bool isDragOverTarget = _isDragOver && canDrop;
        string dragOverClass = isDragOverTarget ? "active-sprint-column-dragover" : "";
        <div class="mb-1">
            <div class="rounded-top" style="height: 6px; background-color: @color;">
            </div>
            <div class="active-sprint-header p-2 border-start border-end border-bottom rounded-bottom">
                <div class="d-flex gap-2">
                    <i class="bi bi-flag-fill fs-6" style="color: @color;"></i>
                    <Typography FontSize="6">
                        @EnumUIConverter.GetInfo(TaskCategory).DisplayText
                    </Typography>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (TaskCategory is HITSTaskStatus.NewTask)
                    {
                        <i class="bi bi-plus active-sprint-add-task p-1 rounded" @onclick="() => ShowTaskModal()"></i>
                    }
                    <Hint Text="@GetHintTaskStatusText(TaskCategory)" IconColor="TextColor.Dark" />
                </div>
            </div>
        </div>
    }
    <div class="list-group active-sprint-column @dragOverClass" @ref="_tableContainer">
        @foreach (var task in _sprintTasks)
        {
            var order = _sprintTasks.IndexOf(task);
            @if (CanDragTask(task))
            {
                <div class="d-flex my-1 task-item task-item-draggable @(_draggedTask?.Id == task.Id ? "task-item-dragging" : "")"
                     data-task-id="@task.Id"
                     style="opacity: @(_draggedTask?.Id == task.Id ? "0.3" : "1"); order: @order"
                     @onmousedown="(e) => HandleMouseDown(e, task)"
                     @onmousemove="HandleMouseMove"
                     @onmouseup="HandleMouseUp"
                     @onmousedown:preventDefault="true">
                    <div class="rounded-start" style="width: 2%; background-color: rgb(@GetTaskExecuteColor(task.Executor));">
                    </div>
                    <div class="bg-white p-2 border-top border-end border-bottom w-100 rounded-end">
                        <div class="d-flex flex-column border-bottom pb-2">
                            <div class="active-sprint-task">
                                <div class="text-ellipsis">@task.Name</div>
                            </div>
                            <div class="d-flex gap-1 text-secondary">
                                @task.Executor?.FullName
                            </div>
                            @if (task.Status is HITSTaskStatus.OnModification && !string.IsNullOrWhiteSpace(task.LeaderComment))
                            {
                                <div class="d-flex gap-1 text-secondary text-info">
                                    <Typography FontSize="6">
                                        <div class="comment">@task.LeaderComment</div>
                                    </Typography>
                                </div>
                            }
                            @if (task.Status is HITSTaskStatus.OnVerification && !string.IsNullOrWhiteSpace(task.ExecutorComment))
                            {
                                <div class="d-flex gap-1 text-secondary text-info">
                                    <Typography FontSize="6">
                                        <div class="comment">@task.ExecutorComment</div>
                                    </Typography>
                                </div>
                            }
                        </div>
                        <Tags AllTags="task.Tags" CustomClass="w-100 mt-2" />
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex my-1 task-item task-item-not-draggable"
                     style="opacity: 1"
                     @onclick="() => ShowSprintTaskModal(task.Id)">
                    <div class="rounded-start" style="width: 2%; background-color: rgb(@GetTaskExecuteColor(task.Executor));">
                    </div>
                    <div class="bg-white p-2 border-top border-end border-bottom w-100 rounded-end">
                        <div class="d-flex flex-column border-bottom pb-2">
                            <div class="active-sprint-task">
                                <div class="text-ellipsis">
                                    @task.Name
                                </div>
                            </div>
                            <div class="d-flex gap-1 text-secondary">
                                @task.Executor?.FullName
                            </div>
                        </div>
                        <Tags AllTags="task.Tags" CustomClass="w-100 mt-2" />
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (_draggedTask is not null)
{
    <div class="drag-overlay" style="left: @($"{_mouseX}px"); top: @($"{_mouseY}px");">
        <div class="drag-card shadow-lg">
            <div class="d-flex">
                <div class="rounded-start" style="width: 2%; background-color: rgb(@GetTaskExecuteColor(_draggedTask.Executor));">
                </div>
                <div class="bg-white p-2 w-100 rounded-end">
                    <div class="d-flex flex-column border-bottom pb-2">
                        <div class="active-sprint-task">
                            <div class="text-ellipsis">@_draggedTask.Name</div>
                        </div>
                        <div class="d-flex gap-1 text-secondary">
                            @_draggedTask.Executor?.FullName
                        </div>
                        @if (_draggedTask.Status is HITSTaskStatus.OnModification && !string.IsNullOrWhiteSpace(_draggedTask.LeaderComment))
                        {
                            <div class="d-flex gap-1 text-secondary text-info">
                                <Typography FontSize="6">
                                    <div class="comment">@_draggedTask.LeaderComment</div>
                                </Typography>
                            </div>
                        }
                        @if (_draggedTask.Status is HITSTaskStatus.OnVerification && !string.IsNullOrWhiteSpace(_draggedTask.ExecutorComment))
                        {
                            <div class="d-flex gap-1 text-secondary text-info">
                                <Typography FontSize="6">
                                    <div class="comment">@_draggedTask.ExecutorComment</div>
                                </Typography>
                            </div>
                        }
                    </div>
                    <Tags AllTags="_draggedTask.Tags" CustomClass="w-100 mt-2" />
                </div>
            </div>
        </div>
    </div>
}