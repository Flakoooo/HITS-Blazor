@namespace HITSBlazor.Components.Button

<button type="@BtnType.ToString().ToLower()" @onclick="@ButtonClick" disabled="@IsLoading"
        class="btn d-flex btn-@(Variant.ToString().ToLower()) @ButtonClass">
    @if (IsLoading.HasValue && IsLoading.Value && string.IsNullOrWhiteSpace(LoadingText))
    {
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        <span>@LoadingText...</span>
    }
    else
    {
        <span>@Text</span>
    }
</button>