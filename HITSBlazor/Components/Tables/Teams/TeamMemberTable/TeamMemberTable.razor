@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.InputSearch
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableComponent
@using HITSBlazor.Pages

<InputSearch Width="50" ValueChanged="@((value) => SearchData(value))" DebounceDelay="500" />
<TableComponent HeaderItems="MembersTableHeader" TableActionMenuIsEnable="true">
    <TableContent>
        @foreach (var member in _teamMembers.OrderBy(tm => tm.UserId != CurrentTeam.Owner?.UserId || tm.Id != CurrentTeam.Leader?.UserId))
        {
            <tr>
                <TableBodyRow>
                    @{
                        var displayInfo = GetRoleDisplayInfo(member.UserId);
                        <div @onclick="() => ShowUserProfile(member.UserId)"
                             class="data-link @(displayInfo.TextColor.HasValue ? $"text-{displayInfo.TextColor.Value.ToString().ToLower()}" : string.Empty)">
                            @member.Email @displayInfo.DisplayText
                        </div>
                    }
                </TableBodyRow>
                <TableBodyRow>
                    @member.FirstName
                </TableBodyRow>
                <TableBodyRow>
                    @member.LastName
                </TableBodyRow>
                <TableActionMenu ItemId="member.Id"
                                 StrategyPosition="Strategy.Fixed"
                                 OnAction="@HandleTableMenuClick"
                                 ActionIds="GetActions(member)" />
            </tr>
        }
    </TableContent>
</TableComponent>