@namespace HITSBlazor.Components.Tags
@using HITSBlazor.Models.Common.Entities

<div class="d-flex flex-wrap gap-2 @CustomClass">
    @foreach (var tag in AllTags)
    {
        <div class="px-2 py-1 rounded-2 text-center align-self-start"
             style="background-color: @($"{tag.Color}4D"); color: @tag.Color;">
            @tag.Name
        </div>
    }
</div>

@code {
    [Parameter]
    public ICollection<Tag> AllTags { get; set; } = [];

    [Parameter]
    public string CustomClass { get; set; } = string.Empty;
}