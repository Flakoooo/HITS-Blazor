@namespace HITSBlazor.Components.Modals.RightSideModals.ProfileModal
@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Charts.SkillRadarChart
@using HITSBlazor.Components.Collapse
@using HITSBlazor.Components.InputDropdowns.SkillDropdown
@using HITSBlazor.Components.InputSearch
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Modals.Components.ModalHeader
@using HITSBlazor.Components.NavigationTabs
@using HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Components.StackCategories
@using HITSBlazor.Components.Statuses.BoolStatus
@using HITSBlazor.Components.Statuses.EnumStatus
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableComponent
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Components.Typography
@using HITSBlazor.Components.UserInfoField
@using HITSBlazor.Models.Common.Entities
@using HITSBlazor.Models.Common.Enums
@using HITSBlazor.Models.Ideas.Enums
@using HITSBlazor.Models.Teams.Entities
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Services.Modal
@using HITSBlazor.Utils.EnumStyles
@using HITSBlazor.Utils.EnumUIConverters
@using HITSBlazor.Utils.Models

<div class="right-side-modal flex-column p-3 overflow-y-scroll" @onclick:stopPropagation="true">
    <RightSideModalHeader IsLoading="_isLoading" HeaderText="@($"{Profile?.FirstName} {Profile?.LastName}")" />
    <div class="right-side-modal-content">
        <div class="d-flex flex-column gap-3 w-75">
            <div class="w-100 bg-white border p-3 rounded-3 d-flex flex-column gap-3" style="height: fit-content;">
                <div class="d-flex justify-content-center w-100">
                    <button class="position-relative p-0 rounded-circle">
                        <img class="text-secondary" width="150" height="150" src="/images//defProfile.png" />
                    </button>
                </div>
                <div class="w-100 d-flex flex-wrap justify-content-center gap-1">
                    @foreach (var role in Profile?.Roles ?? [])
                    {
                        <div class="w-auto">
                            <div class="text-center rounded-pill px-2 py-1 @(_isCurrentUser && role == AuthService.CurrentUser?.Role ? "bg-primary text-light" : "bg-light border p-2")">
                                @EnumUIConverter.GetInfo(role).DisplayText
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="w-100 bg-white border p-3 rounded-3">
                <div class="user-info-header border-bottom pb-1">
                    <Typography FontSize="5" TextColor="TextColor.Primary">
                        Информация
                    </Typography>
                    @if (_isCurrentUser && _editingField != null)
                    {
                        <div class="d-flex justify-content-end gap-2">
                            <Button BtnType="ButtonType.Button"
                                    Variant="ButtonVariant.Success"
                                    OnButtonClick="SaveEdit"
                                    Text="Сохранить" />
                            <Button BtnType="ButtonType.Button"
                                    Variant="ButtonVariant.Danger"
                                    OnButtonClick="CancelEdit"
                                    Text="Отменить" />
                        </div>
                    }
                </div>
                <div class="user-info-content p-2">
                    <UserInfoField Title="Почта"
                                   Value="@Profile?.Email"
                                   ValueChanged="@((value) => value = string.Empty)"
                                   IsEditing="false"
                                   IsCurrentUser="@_isCurrentUser"
                                   OnEdit="@(() => ShowUpdateEmail())" />

                    <UserInfoField Title="Имя"
                                   Value="@_userDataForm?.FirstName"
                                   ValueChanged="@((value) => _userDataForm?.FirstName = value)"
                                   IsEditing="@(_editingField == nameof(_userDataForm.FirstName))"
                                   IsCurrentUser="@_isCurrentUser"
                                   OnEdit="@(() => StartEdit(nameof(_userDataForm.FirstName)))" />

                    <UserInfoField Title="Фамилия"
                                   Value="@_userDataForm?.LastName"
                                   ValueChanged="@((value) => _userDataForm?.LastName = value)"
                                   IsEditing="@(_editingField == nameof(_userDataForm.LastName))"
                                   IsCurrentUser="@_isCurrentUser"
                                   OnEdit="@(() => StartEdit(nameof(_userDataForm.LastName)))" />

                    <UserInfoField Title="Группа"
                                   Value="@_userDataForm?.StudyGroup"
                                   ValueChanged="@((value) => _userDataForm?.StudyGroup = value)"
                                   IsEditing="@(_editingField == nameof(_userDataForm.StudyGroup))"
                                   IsCurrentUser="@_isCurrentUser"
                                   OnEdit="@(() => StartEdit(nameof(_userDataForm.StudyGroup)))" />

                    <UserInfoField Title="Телефон"
                                   Value="@_userDataForm?.Telephone"
                                   ValueChanged="@((value) => _userDataForm?.Telephone = value)"
                                   IsEditing="@(_editingField == nameof(_userDataForm.Telephone))"
                                   IsCurrentUser="@_isCurrentUser"
                                   OnEdit="@(() => StartEdit(nameof(_userDataForm.Telephone)))" />

                    <div class="d-flex gap-1">
                        <Typography FontSize="6" TextColor="TextColor.Primary">
                            Дата регистрации:
                        </Typography>
                        <Typography FontSize="6" TextColor="TextColor.Secondary">
                            @(Profile?.CreatedAt is null ? "-" : Profile.CreatedAt.Value.ToString("dd.MM.yyyy"))
                        </Typography>
                    </div>
                </div>
            </div>
        </div>
        <div class="user-info mb-3">
            <div class="w-100 bg-white border p-3 rounded-3">
                <div class="px-3">
                    <NavigationTabs T="ProfileModalCategory"
                                    Tabs="Enum.GetValues<ProfileModalCategory>()"
                                    ActiveTab="_activeCategory"
                                    ActiveTabChanged="(value) => ChangeCategory(value)"
                                    NavType="NavigationTabType.Tabs"
                                    NavLinkClass="fw-normal pb-1" />
                </div>
                @if (_activeCategory is ProfileModalCategory.General)
                {
                    <div class="d-flex gap-2 mt-3">
                        <div class="bg-white border rounded-3 p-3 w-100">
                            <Typography FontSize="5" TextColor="TextColor.Primary" CustomClass="d-block border-bottom pb-2 mb-3">
                                Компетенции
                            </Typography>
                            @if (Profile?.Skills == null || Profile.Skills.Count == 0)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="text-center py-2">
                                    Компетенции не выбраны
                                </Typography>
                            }
                            else
                            {
                                var languageCount = Profile.Skills.Count(s => s.Type == SkillType.Language);
                                var frameworkCount = Profile.Skills.Count(s => s.Type == SkillType.Framework);
                                var databaseCount = Profile.Skills.Count(s => s.Type == SkillType.Database);
                                var devopsCount = Profile.Skills.Count(s => s.Type == SkillType.Devops);
                
                                @* TODO: вынести в отдельный компонент *@
                                <div class="d-flex flex-wrap gap-3">
                                    @if (languageCount > 0)
                                    {
                                        var uiResult = EnumUIConverter.GetInfo(SkillType.Language);
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 @uiResult.DisplayStyle">
                                            <Typography FontSize="6" TextColor="TextColor.Inherit">
                                                @uiResult.DisplayText
                                            </Typography>
                                            <Typography CustomClass="fw-bold">@languageCount</Typography>
                                        </div>
                                    }
                                    @if (frameworkCount > 0)
                                    {
                                        var uiResult = EnumUIConverter.GetInfo(SkillType.Framework);
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 @uiResult.DisplayStyle">
                                            <Typography FontSize="6" TextColor="TextColor.Inherit">
                                                @uiResult.DisplayText
                                            </Typography>
                                            <Typography CustomClass="fw-bold">@frameworkCount</Typography>
                                        </div>
                                    }
                                    @if (databaseCount > 0)
                                    {
                                        var uiResult = EnumUIConverter.GetInfo(SkillType.Database);
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 @uiResult.DisplayStyle">
                                            <Typography FontSize="6" TextColor="TextColor.Inherit">
                                                @uiResult.DisplayText
                                            </Typography>
                                            <Typography CustomClass="fw-bold">@databaseCount</Typography>
                                        </div>
                                    }
                                    @if (devopsCount > 0)
                                    {
                                        var uiResult = EnumUIConverter.GetInfo(SkillType.Devops);
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 @uiResult.DisplayStyle">
                                            <Typography FontSize="6" TextColor="TextColor.Inherit">
                                                @uiResult.DisplayText
                                            </Typography>
                                            <Typography CustomClass="fw-bold">@devopsCount</Typography>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="bg-white border rounded-3 p-3 w-100">
                            <Typography FontSize="5" TextColor="TextColor.Primary" CustomClass="d-block border-bottom pb-2 mb-3">
                                Идеи
                            </Typography>
                            @if (Profile?.Ideas is null || Profile.Ideas.Count == 0)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="text-center py-2">
                                    Идей пока нет
                                </Typography>
                            }
                            else
                            {
                                var ideasByStatus = Profile.Ideas
                                    .GroupBy(i => i.Status)
                                    .ToDictionary(g => g.Key, g => g.Count());

                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <Typography FontSize="5" TextColor="TextColor.Primary">
                                            Всего идей:
                                        </Typography>
                                        <span class="text-dark">@Profile.Ideas.Count</span>
                                    </div>
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach (var statusGroup in ideasByStatus.OrderBy(x => x.Key))
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                <EnumStatus Statustype="statusGroup.Key" />
                                                <span class="text-dark">@statusGroup.Value</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="bg-white border rounded-3 p-3 w-100">
                            <Typography FontSize="5" TextColor="TextColor.Primary" CustomClass="d-block border-bottom pb-2 mb-3">
                                Команды
                            </Typography>
                            @if (Profile?.Teams == null || Profile.Teams.Count == 0)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="text-center py-2">
                                    Нет участия в командах
                                </Typography>
                            }
                            else
                            {
                                var activeTeams = Profile.Teams.Count(t => t.FinishDate is null);

                                TimeSpan totalTime = TimeSpan.Zero;
                                foreach (var team in Profile.Teams)
                                {
                                    totalTime += (team.FinishDate ?? DateTime.Now) - team.StartDate;
                                }

                                var years = totalTime.Days / 365;
                                var months = (totalTime.Days % 365) / 30;

                                <div class="d-flex flex-wrap gap-4">
                                    <div class="d-flex flex-column">
                                        <Typography FontSize="6" TextColor="TextColor.Secondary">
                                            Всего команд
                                        </Typography>
                                        <Typography FontSize="4" TextColor="TextColor.Primary">
                                            @Profile.Teams.Count
                                        </Typography>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <Typography FontSize="6" TextColor="TextColor.Secondary">
                                            Активных команд
                                        </Typography>
                                        <Typography FontSize="4" TextColor="TextColor.Primary">
                                            @activeTeams
                                        </Typography>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <Typography FontSize="6" TextColor="TextColor.Secondary">
                                            Общий опыт
                                        </Typography>
                                        <Typography FontSize="4" TextColor="TextColor.Primary">
                                            @if (years > 0)
                                            {
                                                <div>@years г. @months мес.</div>
                                            }
                                            else if (months > 0)
                                            {
                                                <div>@months мес.</div>
                                            }
                                            else
                                            {
                                                <div>@totalTime.Days дн.</div>
                                            }
                                        </Typography>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (_activeCategory is ProfileModalCategory.Skills)
                {
                    <div class="d-flex gap-2 flex-column">
                        @if (_isCurrentUser && _isChangeSkills)
                        {
                            @if (_isSkillsLoading)
                            {
                                <div class="mt-2 w-100 d-flex gap-3">
                                    @for (int p = 0; p < 4; ++p)
                                    {
                                        <Placeholder Height="PlaceholderHeight.Small" />
                                    }
                                </div>
                            }
                            else
                            {
                                <StackCategories IsLoading="_isLoading"
                                                 @bind-SelectedLanguageSkills="SelectedLanguageSkills"
                                                 @bind-SelectedFrameworkSkills="SelectedFrameworkSkills"
                                                 @bind-SelectedDatabaseSkills="SelectedDatabaseSkills"
                                                 @bind-SelectedDevopsSkills="SelectedDevopsSkills" />
                            }
                        }
                        else
                        {
                            @if (Profile?.Skills.Count == 0)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="d-flex w-100 justify-content-center mt-3">
                                    Компетенции не выбраны
                                </Typography>
                            }
                            else
                            {
                                <div class="radar-charts">
                                    @if (Profile?.Skills.Count > 0)
                                    {
                                        <SkillRadarChart Options="_skillRadarOptions[SkillType.Language]"
                                                         Skills="Profile?.Skills.Where(s => s.Type == SkillType.Language).ToList()"
                                                         Color="@SkillType.Language.GetColor()" />
                                        <SkillRadarChart Options="_skillRadarOptions[SkillType.Framework]"
                                                         Skills="Profile?.Skills.Where(s => s.Type == SkillType.Framework).ToList()"
                                                         Color="@SkillType.Framework.GetColor()" />
                                        <SkillRadarChart Options="_skillRadarOptions[SkillType.Database]"
                                                         Skills="Profile?.Skills.Where(s => s.Type == SkillType.Database).ToList()"
                                                         Color="@SkillType.Database.GetColor()" />
                                        <SkillRadarChart Options="_skillRadarOptions[SkillType.Devops]"
                                                         Skills="Profile?.Skills.Where(s => s.Type == SkillType.Devops).ToList()"
                                                         Color="@SkillType.Devops.GetColor()" />
                                    }
                                </div>
                            }
                        }
                        @if (_isCurrentUser)
                        {
                            <div class="w-100 d-flex flex-row flex-nowrap justify-content-end mt-3">
                                @if (_isChangeSkills)
                                {
                                    <div class="d-flex gap-2">
                                        <Button Variant="ButtonVariant.Primary"
                                                Text="Сохранить"
                                                OnButtonClick="UpdateUserSkills" />
                                        <Button Variant="ButtonVariant.Danger"
                                                Text="Отменить"
                                                OnButtonClick="() => _isChangeSkills = !_isChangeSkills" />
                                    </div>
                                }
                                else
                                {
                                    <Button Variant="ButtonVariant.Light"
                                            Text="Изменить стек"
                                            OnButtonClick="ChangeToUpdateSkills" />
                                }
                            </div>                            
                        }
                    </div>
                }
                else if (_activeCategory is ProfileModalCategory.Ideas)
                {
                    <div class="d-flex gap-2 @(Profile?.Ideas.Count > 0 ? "mt-3" : string.Empty)">
                        <div class="w-100 d-flex flex-column flex-nowrap gap-2">
                            @if (Profile?.Ideas.Count == 0)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="d-flex w-100 justify-content-center mt-3">
                                    Идей пока нет
                                </Typography>
                            }
                            else
                            {
                                @foreach (var idea in Profile?.Ideas ?? [])
                                {
                                    <div class="user-ideas-idea w-100 p-2 bg-white border rounded">
                                        <Collapse ExpandedClass="w-100" StartCollapsed="true">
                                            <MainContent Context="collapse">
                                                <div class="w-100 d-flex justify-content-between align-items-center gap-3">
                                                    <div class="w-100 d-flex gap-2 align-items-center justify-content-between">
                                                        <div @onclick="@(() => ShowIdea(idea.Id))" class="user-ideas-idea-link data-link fs-6 w-100">
                                                            @idea.Name
                                                        </div>
                                                        <EnumStatus Statustype="idea.Status" CustomClass="fs-6 text-center" />
                                                    </div>
                                                    <div @onclick="@(() => collapse.Toggle())" class="d-flex align-items-center gap-1" style="cursor: pointer;">
                                                        <Typography FontSize="6" TextColor="TextColor.Primary">
                                                            Описание
                                                        </Typography>
                                                        <i class="bi bi-caret-down text-primary flip-icon @(collapse.ExpandedStatus ? "active" : string.Empty)"></i>
                                                    </div>
                                                </div>
                                            </MainContent>
                                            <ExpandedContent>
                                                <div class="list-group">
                                                    <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="w-100 mt-1 border-top">
                                                        @idea.Description
                                                    </Typography>
                                                </div>
                                            </ExpandedContent>
                                        </Collapse>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
                else if (_activeCategory is ProfileModalCategory.Teams)
                {
                    <div class="d-flex gap-2 flex-column">
                        @if (Profile?.Teams.Count == 0)
                        {
                            <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="d-flex w-100 justify-content-center mt-3">
                                Нет участия в командах
                            </Typography>
                        }
                        else
                        {
                            <InputSearch IsLoading="_isLoading" ValueChanged="(value) => SearchTeamExperience(value)" />
                            <TableComponent HeaderItems="HeaderItems" TableActionMenuIsEnable="true">
                                <TableContent>
                                    @foreach (var teamExp in Profile?.Teams ?? [])
                                    {
                                        <tr>
                                            <TableBodyRow>
                                                <div class="data-link" 
                                                     @onclick="() => OnTeamAction(new() { Action = MenuAction.View, Item = teamExp.TeamId })">
                                                    @teamExp.TeamName
                                                </div>
                                            </TableBodyRow>
                                            <TableBodyRow IsCentered="true">
                                                @teamExp.StartDate.ToString("dd.MM.yyyy")
                                            </TableBodyRow>
                                            <TableBodyRow IsCentered="true">
                                                <div class="@(teamExp.FinishDate is null ? "text-primary" : string.Empty)">
                                                    @(teamExp.FinishDate is null ? "В команде" : teamExp.FinishDate.Value.ToString("dd.MM.yyyy"))
                                                </div>
                                            </TableBodyRow>
                                            <TableBodyRow IsCentered="true">
                                                <BoolStatus Value="teamExp.HasActiveProject" StatusType="BoolStatusType.TeamActiveProject" />
                                            </TableBodyRow>
                                            <TableActionMenu ItemId="@teamExp.TeamId"
                                                             StrategyPosition="Strategy.Fixed"
                                                             OnAction="OnTeamAction"
                                                             ActionIds="new() { [MenuAction.View] = teamExp.TeamId }" />
                                        </tr>
                                    }
                                </TableContent>
                            </TableComponent>
                        }
                    </div>
                }
                else if (_activeCategory is ProfileModalCategory.Tests)
                {
                    <div class="d-flex gap-2 flex-column">
                        <div class="user-tests-content mt-3">
                            <Typography FontSize="6" CustomClass="text-decoration-underline">
                                Тест Белбина:
                            </Typography>
                            @if (BelbinTestResult is null)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary">
                                    Вы не прошли тест
                                </Typography>
                            }
                            else
                            {
                                <p>@((MarkupString)BelbinTestResult.TestResultValue.Replace("\n", "<br>"))</p>
                            }
                        </div>
                        <div class="user-tests-content mt-3">
                            <Typography FontSize="6" CustomClass="text-decoration-underline">
                                Айзенка личностный опросник:
                            </Typography>
                            @if (TemperTestResult is null)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary">
                                    Вы не прошли тест
                                </Typography>
                            }
                            else
                            {
                                <p>@((MarkupString)TemperTestResult.TestResultValue.Replace("\n", "<br>"))</p>
                            }
                        </div>
                        <div class="user-tests-content mt-3">
                            <Typography FontSize="6" CustomClass="text-decoration-underline">
                                Опросник «Стиль мышления»:
                            </Typography>
                            @if (MindTestResult is null)
                            {
                                <Typography FontSize="6" TextColor="TextColor.Secondary">
                                    Вы не прошли тест
                                </Typography>
                            }
                            else
                            {
                                <p>@((MarkupString)MindTestResult.TestResultValue.Replace("\n", "<br>"))</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>