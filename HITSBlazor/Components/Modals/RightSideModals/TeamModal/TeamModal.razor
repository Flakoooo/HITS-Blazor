@namespace HITSBlazor.Components.Modals.RightSideModals.TeamModal
@using HITSBlazor.Components.ActionMenus.BaseActionMenu
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Collapse
@using HITSBlazor.Components.InputSearch
@using HITSBlazor.Components.Modals.Components
@using HITSBlazor.Components.Modals.Components.ModalHeader
@using HITSBlazor.Components.Modals.Components.RightSideModaCollapselInfo
@using HITSBlazor.Components.Modals.Components.RightSideModalInfo
@using HITSBlazor.Components.NavigationTabs
@using HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Components.Skills
@using HITSBlazor.Components.Statuses.EnumStatus
@using HITSBlazor.Components.Tables.InvitationTeamToIdeaTable
@using HITSBlazor.Components.Tables.TableActionMenu
@using HITSBlazor.Components.Tables.TableBodyRow
@using HITSBlazor.Components.Tables.TableComponent
@using HITSBlazor.Components.Tables.TableHeader
@using HITSBlazor.Components.Tables.TeamInvitationTable
@using HITSBlazor.Components.Tables.TeamMemberTable
@using HITSBlazor.Components.Tables.TeamRequestsToTeamTable
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Common.Entities
@using HITSBlazor.Models.Common.Enums
@using HITSBlazor.Models.Teams.Enums
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Utils.EnumStyles
@using HITSBlazor.Utils.Models

<div class="right-side-modal p-3 overflow-y-scroll" @onclick:stopPropagation="true">
    @if (_isLoading || _currentTeam is null)
    {
        <div class="team-modal-placeholder w-75 h-100">
            <Placeholder Width="w-75" />
            <div class="p-2 bg-white rounded-3 d-flex flex-column gap-1">
                <Placeholder Width="w-50" />
                <Placeholder />
                <Placeholder />
            </div>
            <div class="w-100">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            @for (int i = 0; i < 6; ++i)
                            {
                                <th>
                                    <Placeholder />
                                </th>                                
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < 5; ++i)
                        {
                            <tr>
                                <td>
                                    <div class="h-100 d-flex align-items-center">
                                        <Placeholder />
                                    </div>
                                </td>
                                @for (int j = 0; j < 5; ++j)
                                {
                                    <td>
                                        <div class="h-100 d-flex align-items-center">
                                            <Placeholder Height="PlaceholderHeight.Small" />
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-2 bg-white rounded-3 gap-2 d-flex">
                <Placeholder Width="w-25" Height="PlaceholderHeight.Small" />
                <Placeholder Width="w-25" Height="PlaceholderHeight.Small" />
                <Placeholder Width="w-25" Height="PlaceholderHeight.Small" />
            </div>
        </div>
        <div class="team-modal-placeholder p-2 w-25 bg-white rounded">
            <div class="d-flex gap-2 w-100 px-1 pt-1">
                <div class="bg-primary w-50 py-3 rounded-3"></div>
                <div class="bg-primary w-50 py-3 rounded-3"></div>
            </div>
            <div class="px-1">
                <Placeholder Width="w-50" />
                <Placeholder />
                <Placeholder />
            </div>
            <div class="px-1">
                <Placeholder Width="w-50" />
                <Placeholder />
                <Placeholder />
                <Placeholder />
            </div>
            <div class="px-1 pb-1">
                <Placeholder />
                <Placeholder Width="w-75" />
                <Placeholder Width="w-75" />
            </div>
        </div>
    }
    else
    {
        <div class="team-modal-side w-75">
            <RightSideModalHeader HeaderText="@_currentTeam.Name" />
            <RightSideModaCollapselInfo Data="_teamData" />
            <div class="bg-white rounded-3">
                <div class="border-bottom px-3">
                    <NavigationTabs T="TeamTableCategory" 
                                    Tabs="Enum.GetValues<TeamTableCategory>()" 
                                    ActiveTab="_activeTableCategory"
                                    ActiveTabChanged="(value) => ChangeCategory(value)"
                                    NavType="NavigationTabType.Underline"
                                    NavLinkClass="fw-normal pb-1" />
                </div>
                <div class="team-modal-tables">
                    <div class="w-100 bg-white px-3 pb-3 pt-1">
                        @if (_activeTableCategory is TeamTableCategory.Members)
                        {
                            <TeamMemberTable CurrentTeam="_currentTeam" />
                        }
                        else if (_activeTableCategory is TeamTableCategory.Invitations)
                        {
                            <TeamInvitationTable CurrentTeam="_currentTeam" />
                        }
                        else if (_activeTableCategory is TeamTableCategory.RequestsToTeam)
                        {
                            <TeamRequestsToTeamTable CurrentTeam="_currentTeam" />
                        }
                        else if (_activeTableCategory is TeamTableCategory.RequestsTeamToIdeas)
                        {
                            <TeamRequestsToTeamTable CurrentTeam="_currentTeam" />
                        }
                        else if (_activeTableCategory is TeamTableCategory.InvitationsTeamToIdeas)
                        {
                            <InvitationTeamToIdeaTable CurrentTeam="_currentTeam" />
                        }
                    </div>
                </div>
            </div>
            @{
                var currentUser = AuthService.CurrentUser;
                @if (currentUser is not null)
                {
                    var isAdmin = currentUser.Role is RoleType.Admin;
                    var isOwner = currentUser.Id == _currentTeam.Owner.Id;
                    var isLeader = currentUser.Id == _currentTeam.Leader?.Id;
                    <div class="rounded-3 bg-white p-3 d-flex flex-wrap gap-3">
                        @if (isAdmin || isOwner || isLeader)
                        {
                            <Button Variant="ButtonVariant.Light"
                                    Text="Редактировать"
                                    OnButtonClick="NavigateToCreateTeam" />
                            @if (!isLeader)
                            {
                                <Button Variant="ButtonVariant.Danger"
                                        Text="Удалить команду"
                                        OnButtonClick="DeleteTeam" />
                            }
                            <Button Variant="ButtonVariant.Primary"
                                    Text="Пригласить пользователя"
                                    OnButtonClick="ShowInviteUsersModal" />
                        }
                        else
                        {
                            @* TODOO: реализовать *@
                            <Button Variant="ButtonVariant.Success"
                                    Text="Подать заявку в команду"
                                    OnButtonClick="ShowInviteUsersModal" />
                        }
                    </div>
                }
            }
        </div>
        <RightSideModalInfo Skills1="_currentTeam.Skills" 
                            Skills1Label="Желаемые компетенции"     
                            Skills2="_currentTeam.WantedSkills" 
                            Skills2Label="Фактические компетенции" 
                            Items="_infoItems" 
                            SearhButtonTest="Поделиться командой" />
    }
</div>