@namespace HITSBlazor.Components.Modals.RightSideModals.IdeaMarketModal
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Modals.Components
@using HITSBlazor.Components.Typography
@using HITSBlazor.Utils.Models

<div class="p-3 h-100 overflow-y-scroll idea-market-modal" @onclick:stopPropagation="true">
    <div class="idea-market-modal-left-side w-75">

    </div>
    <div class="w-25 rounded">
        <div class="w-100 right-side">
            <div class="right-side-header w-100 p-2 bg-white rounded">
                <Button ButtonClass="@($"w-50 {GetInfoCategoryClass(RightSideModalCategory.Info)}")"
                        Text="@(EnumViewModel<RightSideModalCategory>.GetTranslation(RightSideModalCategory.Info))"
                        OnButtonClick="() => _activeInfoCategory = RightSideModalCategory.Info" />
                <Button ButtonClass="@($"w-50 {GetInfoCategoryClass(RightSideModalCategory.Skills)}")"
                        Text="@(EnumViewModel<RightSideModalCategory>.GetTranslation(RightSideModalCategory.Skills))"
                        OnButtonClick="() => _activeInfoCategory = RightSideModalCategory.Skills" />
            </div>
            <div class="bg-white rounded w-100 mb-1">
                <div class="exchange-header w-100 bg-primary rounded-top fs-5 text-white p-2">
                    @(EnumViewModel<RightSideModalCategory>.GetTranslation(_activeInfoCategory))
                </div>
                <div class="exchange-info w-100 p-3">
                    <div>
                        <Typography FontSize="6" TextColor="TextColor.Secondary" CustomClass="border-bottom d-block">
                            Заказчик
                        </Typography>
                        <div class="exchange-info-user pt-2">
                            <i class="bi bi-person-circle text-secondary fs-2 opacity-25"></i>
                            <div class="text-primary">@CurrentIdeaMarket.Customer</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>