@namespace HITSBlazor.Components.Modals.CenterModals.UsersGroupModal
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Inputs.CheckboxDropdown
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Modals.Components.CenterModalHeader
@using HITSBlazor.Components.Placeholders.Placeholder
@using HITSBlazor.Components.Typography
@using HITSBlazor.Components.UsersColumn
@using HITSBlazor.Models.Users.Enums
@using HITSBlazor.Utils.Models

<div @onclick:stopPropagation="true" class="users-group-modal p-3 bg-white rounded-3">
    <CenterModalHeader IsLoading="_isLoading" HeaderText="@(UsersGroupId.HasValue ? "Редактирование группы" : "Создание группы")" />
    <Input IsLoading="_isLoading"
           Label="Название группы:"
           Placeholder="Введите название группы"
           @bind-Value="UsersGroupName" />
    <div class="d-flex justify-content-between gap-3">
        <UsersColumn IsLoading="_isLoading"
                     HeaderText="Пользователи:"
                     SelectedUserChanged="AddUser"
                     DataLoaderMethod="async (page, searchText) => await UserService.GetUsersAsync(page, searchText: searchText)"
                     DebounceDelay="500"
                     DisplayPredicate="(user) => !GroupMembers.Contains(user) && !MembersForAdd.Contains(user)"
                     DisplayTextColorPredicate="(user) => MembersForRemove.Contains(user) ? TextColor.Danger : null" />
        <UsersColumn IsLoading="_isLoading"
                     HeaderText="Представители в группе:"
                     SelectedUserChanged="RemoveUser"
                     @bind-AllUsers="GroupMembers"
                     AdditionalUsers="MembersForAdd"
                     DataLoaderMethod="async (page, searchText) => UsersGroupId.HasValue
                            ? await UsersGroupsService.GetUsersGroupMembersAsync(UsersGroupId.Value, page, searchText: searchText)
                            : null"
                     DebounceDelay="500"
                     DisplayPredicate="(user) => !MembersForRemove.Contains(user)"
                     DisplayTextColorPredicate="(user) => MembersForAdd.Contains(user) ? TextColor.Success : null" />
    </div>
    <CheckboxDropdown T="EnumViewModel<RoleType>"
                      IsLoading="_isLoading"
                      AllValues="AllRoles"
                      Label="Выберите тип группы:"
                      Placeholder="Выбрано"
                      @bind-SelectedValues="SelectedRoles" />
    <Button Variant="ButtonVariant.Primary"
            IsLoading="_isLoading"
            InProgress="_submitting"
            Text="@(UsersGroupId.HasValue ? "Сохранить изменения" : "Добавить")"
            LoadingText="@(UsersGroupId.HasValue ? "Сохранение" : "Добавление")"
            OnButtonClick="SendUsersGroup" />
</div>