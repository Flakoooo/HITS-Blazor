@namespace HITSBlazor.Components.Modals.CenterModals.TaskModal
@using HITSBlazor.Components.Button
@using HITSBlazor.Components.Inputs.CheckboxDropdown
@using HITSBlazor.Components.Inputs.Input
@using HITSBlazor.Components.Inputs.Number
@using HITSBlazor.Components.Inputs.TextArea
@using HITSBlazor.Components.Modals.Components.CenterModalHeader
@using HITSBlazor.Components.Typography
@using HITSBlazor.Models.Common.Entities
@using HITSBlazor.Utils.Models

<div @onclick:stopPropagation="true" class="add-task-modal border rounded-3 bg-white px-3 py-2">
    <CenterModalHeader IsLoading="_isLoading" HeaderText="@(CurrentTask is null ? "Создание задачи" : "Редактирвоание задачи")" FontSize="4" />
    <Input IsLoading="_isLoading" Label="Название задачи*" Placeholder="Название" @bind-Value="TaskName" />
    <TextArea IsLoading="_isLoading" Label="Описание задачи*" Placeholder="Описание" @bind-Value="TaskDescription" Style="resize: none; height: 100px;" />
    <CheckboxDropdown T="Tag" 
                      IsLoading="_isLoading" 
                      @bind-SelectedValues="SelectedTags" 
                      Placeholder="Теги"
                      DataLoaderMethod="async (page, searchText) => await TagService.GetTagsAsync(page, searchText)"
                      DebounceDelay="500"/>
    <div class="d-flex flex-wrap gap-2">
        @foreach (var tag in SelectedTags)
        {
            <div class="d-flex gap-1">
                <i class="bi bi-circle-fill p-1 rounded-2" style="color: @tag.Color; background-color: @($"{tag.Color}4D");"></i>
                @tag.Name
            </div>
        }
    </div>
    <div class="d-flex align-items-center gap-2 w-100">
        <Typography FontSize="6" TextColor="TextColor.Primary">
            Трудоёмкость*
        </Typography>
        <Number IsLoading="_isLoading" Placeholder="Часы" @bind-Value="Hours" MinValue="0" />
    </div>
    @* TODOO: добавить метод *@
    <Button IsLoading="_isLoading" 
            Variant="ButtonVariant.Primary" 
            Text="Создать задачу" 
            ButtonClass="w-100 mb-1" />
</div>